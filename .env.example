# Copy to `.env` in this folder. This service uses MongoDB (Mongoose), not PostgreSQL.
PORT=5004
MONGODB_URI=mongodb://localhost:27017/safetrade-messaging

# Required for push notifications (must match docker-compose rabbitmq)
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# Firebase Admin — download JSON from Firebase Console → Project settings → Service accounts → Generate new private key
# Option A (recommended local dev): save file as firebase-service-account.json in this folder (gitignored)
FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json
# Option B: paste entire JSON on one line
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"paynexa-fc9ca",...}
